{
  "manifest_version": 3,
  "name": "Strava Elevate MVP",
  "version": "0.1.0",
  "description": "Adds premium analytics overlays to the Strava web experience.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.strava.com/*",
    "https://www.strava.com/api/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.strava.com/*"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Strava Elevate MVP"
  }
}
